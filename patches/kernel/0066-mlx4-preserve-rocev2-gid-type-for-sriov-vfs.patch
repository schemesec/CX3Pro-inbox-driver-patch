From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: scheme <scheme@scheme.home.schemesec.com>
Date: Wed, 20 May 2026 00:00:00 -0400
Subject: [PATCH] mlx4: preserve RoCEv2 GID type for SR-IOV VFs

The mlx4 PF command wrapper allowed SR-IOV VFs to update their RoCE GID
entries through MLX4_SET_PORT_GID_TABLE, but rejected
MLX4_SET_PORT_ROCE_ADDR.  The older GID table command carries only the raw
GID bytes, while the RoCE address command also carries the RoCE version.

As a result, a VF could not expose RoCE v2 GIDs through the PF-managed GID
cache.  mlx4_ib later reads that cache when building packets for VFs, but it
only recovered the GID bytes and therefore could not identify a cached VF GID
as RoCE v2/UDP-encapsulated.

Allow VF MLX4_SET_PORT_ROCE_ADDR updates, store the per-entry RoCE GID type
alongside the existing raw GID cache, and return that type to mlx4_ib so VF
traffic using RoCE v2 GIDs is encoded as RoCE v2.  Preserve duplicate-GID
rejection for duplicate GID/type pairs while allowing the normal RoCEv1 and
RoCEv2 entries that share the same raw GID bytes.

For CX3 Pro SR-IOV testing, keep the firmware RoCE v1/v2 capability visible
in multifunction mode by default so the inbox RDMA core creates both v1 and
v2 GIDs.  This can be disabled with mlx4_core.enable_mfunc_roce_v2=0.

Keep SR-IOV VF RoCE GID allocation within source GID indexes below 64.
The PF firmware table remains 128 entries, but CX3 Pro data QPs fail work
completion when higher-numbered VFs use source GID indexes above 63.

Signed-off-by: scheme <scheme@scheme.home.schemesec.com>
---
diff --git a/drivers/infiniband/hw/mlx4/ah.c b/drivers/infiniband/hw/mlx4/ah.c
index 7321d6ab5fe1..fea0ad315d40 100644
--- a/drivers/infiniband/hw/mlx4/ah.c
+++ b/drivers/infiniband/hw/mlx4/ah.c
@@ -108,6 +108,8 @@ static int create_iboe_ah(struct ib_ah *ib_ah, struct rdma_ah_attr *ah_attr)
 		if (ret < 0)
 			return ret;
 		ah->av.eth.gid_index = ret;
+		ah->gid_type = gid_attr->gid_type;
+		ah->gid_type_valid = true;
 	} else {
 		/* mlx4_ib_create_ah_slave fills in the s_mac and the vlan */
 		ah->av.eth.gid_index = ah_attr->grh.sgid_index;
@@ -181,6 +183,29 @@ int mlx4_ib_create_ah_slave(struct ib_ah *ah, struct rdma_ah_attr *ah_attr,
 
 	ah->type = ah_attr->type;
 
+	if (ah_attr->type == RDMA_AH_ATTR_TYPE_ROCE) {
+		const struct ib_global_route *grh = rdma_ah_read_grh(ah_attr);
+
+		if (grh->sgid_attr) {
+			mah->gid_type = grh->sgid_attr->gid_type;
+			mah->gid_type_valid = true;
+		} else {
+			enum mlx4_roce_gid_type gid_type;
+			union ib_gid gid;
+
+			ret = mlx4_get_roce_gid_from_slave(to_mdev(ah->device)->dev,
+							rdma_ah_get_port_num(ah_attr),
+							slave_sgid_index,
+							gid.raw, &gid_type);
+			if (!ret) {
+				mah->gid_type = gid_type == MLX4_ROCE_GID_TYPE_V2 ?
+					IB_GID_TYPE_ROCE_UDP_ENCAP :
+					IB_GID_TYPE_ROCE;
+				mah->gid_type_valid = true;
+			}
+		}
+	}
+
 	/* get rid of force-loopback bit */
 	mah->av.ib.port_pd &= cpu_to_be32(0x7FFFFFFF);
 
diff --git a/drivers/infiniband/hw/mlx4/main.c b/drivers/infiniband/hw/mlx4/main.c
index 63360c5a73c7..85eb1870cf98 100644
--- a/drivers/infiniband/hw/mlx4/main.c
+++ b/drivers/infiniband/hw/mlx4/main.c
@@ -2829,7 +2829,8 @@ static int mlx4_ib_probe(struct auxiliary_device *adev,
 			goto err_notif;
 		}
 	}
-	if (dev->caps.flags2 & MLX4_DEV_CAP_FLAG2_ROCE_V1_V2) {
+	if (!mlx4_is_slave(dev) &&
+	    dev->caps.flags2 & MLX4_DEV_CAP_FLAG2_ROCE_V1_V2) {
 		err = mlx4_config_roce_v2_port(dev, ROCE_V2_UDP_DPORT);
 		if (err)
 			goto err_notif;
diff --git a/drivers/infiniband/hw/mlx4/mlx4_ib.h b/drivers/infiniband/hw/mlx4/mlx4_ib.h
index 5df5b955114e..1a728f61949b 100644
--- a/drivers/infiniband/hw/mlx4/mlx4_ib.h
+++ b/drivers/infiniband/hw/mlx4/mlx4_ib.h
@@ -389,6 +389,8 @@ struct mlx4_ib_srq {
 struct mlx4_ib_ah {
 	struct ib_ah		ibah;
 	union mlx4_ext_av       av;
+	enum ib_gid_type	gid_type;
+	bool			gid_type_valid;
 };
 
 struct mlx4_ib_rwq_ind_table {
diff --git a/drivers/infiniband/hw/mlx4/qp.c b/drivers/infiniband/hw/mlx4/qp.c
index 1cb890d3d93c..192d52ee4308 100644
--- a/drivers/infiniband/hw/mlx4/qp.c
+++ b/drivers/infiniband/hw/mlx4/qp.c
@@ -1695,12 +1695,11 @@ static int _mlx4_ib_destroy_qp(struct ib_qp *qp, struct ib_udata *udata)
 int mlx4_ib_destroy_qp(struct ib_qp *qp, struct ib_udata *udata)
 {
 	struct mlx4_ib_qp *mqp = to_mqp(qp);
+	struct mlx4_ib_sqp *sqp = mqp->sqp;
 
-	if (mqp->mlx4_ib_qp_type == MLX4_IB_QPT_GSI) {
-		struct mlx4_ib_sqp *sqp = mqp->sqp;
-
-		if (sqp->roce_v2_gsi)
+	if (sqp && sqp->roce_v2_gsi) {
 			ib_destroy_qp(sqp->roce_v2_gsi);
+			sqp->roce_v2_gsi = NULL;
 	}
 
 	return _mlx4_ib_destroy_qp(qp, udata);
@@ -3048,17 +3047,29 @@ static int build_mlx_header(struct mlx4_ib_qp *qp, const struct ib_ud_wr *wr,
 	is_eth = rdma_port_get_link_layer(qp->ibqp.device, qp->port) == IB_LINK_LAYER_ETHERNET;
 	is_grh = mlx4_ib_ah_grh_present(ah);
 	if (is_eth) {
-		enum ib_gid_type gid_type;
 		if (mlx4_is_mfunc(to_mdev(ib_dev)->dev)) {
+			enum mlx4_roce_gid_type gid_type;
+
 			/* When multi-function is enabled, the ib_core gid
 			 * indexes don't necessarily match the hw ones, so
 			 * we must use our own cache */
 			err = mlx4_get_roce_gid_from_slave(to_mdev(ib_dev)->dev,
 							   be32_to_cpu(ah->av.ib.port_pd) >> 24,
-							   ah->av.ib.gid_index, &sgid.raw[0]);
+							   ah->av.ib.gid_index, &sgid.raw[0],
+							   &gid_type);
 			if (err)
 				return err;
+			is_udp = gid_type == MLX4_ROCE_GID_TYPE_V2;
+			if (is_udp) {
+				if (ipv6_addr_v4mapped((struct in6_addr *)&sgid))
+					ip_version = 4;
+				else
+					ip_version = 6;
+				is_grh = false;
+			}
 		} else  {
+			enum ib_gid_type gid_type;
+
 			err = fill_gid_by_hw_index(ibdev, qp->port,
 						   ah->av.ib.gid_index, &sgid,
 						   &gid_type);
@@ -3553,15 +3564,21 @@ static int _mlx4_ib_post_send(struct ib_qp *ibqp, const struct ib_send_wr *wr,
 			struct mlx4_ib_ah *ah = to_mah(ud_wr(wr)->ah);
 			enum ib_gid_type gid_type;
 			union ib_gid gid;
+			int err = 0;
+
+			if (ah->gid_type_valid) {
+				gid_type = ah->gid_type;
+			} else if (fill_gid_by_hw_index(mdev, qp->port,
+							   ah->av.ib.gid_index,
+							   &gid, &gid_type)) {
+				err = -ENOENT;
+				pr_err("Failed to get gid at index %d. RoCEv2 will not work properly\n",
+				       ah->av.ib.gid_index);
+			}
 
-			if (!fill_gid_by_hw_index(mdev, qp->port,
-					   ah->av.ib.gid_index,
-					   &gid, &gid_type))
+			if (!err)
 				qp = (gid_type == IB_GID_TYPE_ROCE_UDP_ENCAP) ?
 						to_mqp(sqp->roce_v2_gsi) : qp;
-			else
-				pr_err("Failed to get gid at index %d. RoCEv2 will not work properly\n",
-				       ah->av.ib.gid_index);
 		}
 	}
 
diff --git a/drivers/net/ethernet/mellanox/mlx4/fw.c b/drivers/net/ethernet/mellanox/mlx4/fw.c
index 0005d9e2c2d6..cb614f2e6eea 100644
--- a/drivers/net/ethernet/mellanox/mlx4/fw.c
+++ b/drivers/net/ethernet/mellanox/mlx4/fw.c
@@ -42,6 +42,11 @@
 #include "fw.h"
 #include "icm.h"
 
+static bool enable_mfunc_roce_v2 = true;
+module_param_named(enable_mfunc_roce_v2, enable_mfunc_roce_v2, bool, 0444);
+MODULE_PARM_DESC(enable_mfunc_roce_v2,
+		 "Expose RoCE v1/v2 capability in multifunction mode (default: true)");
+
 enum {
 	MLX4_COMMAND_INTERFACE_MIN_REV		= 2,
 	MLX4_COMMAND_INTERFACE_MAX_REV		= 3,
@@ -1399,7 +1404,8 @@ static void disable_unsupported_roce_caps(void *buf)
 	flags &= ~(1UL << 24);
 	MLX4_PUT(buf, flags, QUERY_DEV_CAP_EXT_2_FLAGS_OFFSET);
 	MLX4_GET(flags, buf, QUERY_DEV_CAP_BMME_FLAGS_OFFSET);
-	flags &= ~(MLX4_FLAG_ROCE_V1_V2);
+	if (!enable_mfunc_roce_v2)
+		flags &= ~(MLX4_FLAG_ROCE_V1_V2);
 	MLX4_PUT(buf, flags, QUERY_DEV_CAP_BMME_FLAGS_OFFSET);
 }
 
diff --git a/drivers/net/ethernet/mellanox/mlx4/mlx4.h b/drivers/net/ethernet/mellanox/mlx4/mlx4.h
index b213094ea30f..1340875db2f1 100644
--- a/drivers/net/ethernet/mellanox/mlx4/mlx4.h
+++ b/drivers/net/ethernet/mellanox/mlx4/mlx4.h
@@ -761,6 +761,7 @@ struct mlx4_roce_gid_entry {
 
 struct mlx4_roce_gid_table {
 	struct mlx4_roce_gid_entry	roce_gids[MLX4_ROCE_MAX_GIDS];
+	enum mlx4_roce_gid_type	gid_type[MLX4_ROCE_MAX_GIDS];
 	struct mutex			mutex;
 };
 
diff --git a/drivers/net/ethernet/mellanox/mlx4/port.c b/drivers/net/ethernet/mellanox/mlx4/port.c
index e3d0b13c1610..36d1c8b33aec 100644
--- a/drivers/net/ethernet/mellanox/mlx4/port.c
+++ b/drivers/net/ethernet/mellanox/mlx4/port.c
@@ -34,6 +34,7 @@
 #include <linux/if_ether.h>
 #include <linux/if_vlan.h>
 #include <linux/export.h>
+#include <net/ipv6.h>
 
 #include <linux/mlx4/cmd.h>
 
@@ -93,8 +94,10 @@ void mlx4_init_roce_gid_table(struct mlx4_dev *dev,
 	int i;
 
 	mutex_init(&table->mutex);
-	for (i = 0; i < MLX4_ROCE_MAX_GIDS; i++)
+	for (i = 0; i < MLX4_ROCE_MAX_GIDS; i++) {
 		memset(table->roce_gids[i].raw, 0, MLX4_ROCE_GID_ENTRY_SIZE);
+		table->gid_type[i] = MLX4_ROCE_GID_TYPE_INVALID;
+	}
 }
 
 static int validate_index(struct mlx4_dev *dev,
@@ -1069,6 +1072,61 @@ int mlx4_get_port_ib_caps(struct mlx4_dev *dev, u8 port, __be32 *caps)
 }
 static struct mlx4_roce_gid_entry zgid_entry;
 
+struct mlx4_roce_addr_mbox_entry {
+	u8		gid[MLX4_ROCE_GID_ENTRY_SIZE];
+	__be32		rsrvd1[2];
+	__be16		rsrvd2;
+	u8		type;
+	u8		version;
+	__be32		rsrvd3;
+};
+
+static void mlx4_fill_roce_addr_mbox(struct mlx4_roce_gid_table *table,
+				     void *buf)
+{
+	struct mlx4_roce_addr_mbox_entry *entry = buf;
+	int i;
+
+	for (i = 0; i < MLX4_ROCE_MAX_GIDS; i++, entry++) {
+		memset(entry, 0, sizeof(*entry));
+		memcpy(entry->gid, table->roce_gids[i].raw,
+		       MLX4_ROCE_GID_ENTRY_SIZE);
+		if (table->gid_type[i] == MLX4_ROCE_GID_TYPE_V2) {
+			entry->version = 2;
+			if (!ipv6_addr_v4mapped((struct in6_addr *)entry->gid))
+				entry->type = 1;
+		}
+	}
+}
+
+static bool mlx4_roce_addr_entry_valid(struct mlx4_roce_addr_mbox_entry *entry)
+{
+	if (!memcmp(entry->gid, zgid_entry.raw, MLX4_ROCE_GID_ENTRY_SIZE))
+		return true;
+
+	return entry->version == MLX4_ROCE_GID_TYPE_V1 ||
+	       entry->version == MLX4_ROCE_GID_TYPE_V2;
+}
+
+static bool mlx4_roce_addr_entries_equal(struct mlx4_roce_addr_mbox_entry *e1,
+					 struct mlx4_roce_addr_mbox_entry *e2)
+{
+	return e1->version == e2->version &&
+	       !memcmp(e1->gid, e2->gid, MLX4_ROCE_GID_ENTRY_SIZE);
+}
+
+/* CX3 Pro accepts a 128-entry RoCE GID table, but data QP contexts only
+ * complete reliably with source GID indexes below 64 in SR-IOV mode.
+ * Keep PF/VF GID allocation inside that range instead of letting higher
+ * numbered VFs receive indexes that the QP path cannot use.
+ */
+#define MLX4_ROCE_MFUNC_QP_GIDS 64
+
+static int mlx4_roce_mfunc_gid_limit(void)
+{
+	return min_t(int, MLX4_ROCE_MAX_GIDS, MLX4_ROCE_MFUNC_QP_GIDS);
+}
+
 int mlx4_get_slave_num_gids(struct mlx4_dev *dev, int slave, int port)
 {
 	int vfs;
@@ -1100,9 +1158,9 @@ int mlx4_get_slave_num_gids(struct mlx4_dev *dev, int slave, int port)
 					   dev->persist->num_vfs + 1);
 	}
 	vfs = bitmap_weight(slaves_pport.slaves, dev->persist->num_vfs + 1) - 1;
-	if (slave_gid <= ((MLX4_ROCE_MAX_GIDS - MLX4_ROCE_PF_GIDS) % vfs))
-		return ((MLX4_ROCE_MAX_GIDS - MLX4_ROCE_PF_GIDS) / vfs) + 1;
-	return (MLX4_ROCE_MAX_GIDS - MLX4_ROCE_PF_GIDS) / vfs;
+	if (slave_gid <= ((mlx4_roce_mfunc_gid_limit() - MLX4_ROCE_PF_GIDS) % vfs))
+		return ((mlx4_roce_mfunc_gid_limit() - MLX4_ROCE_PF_GIDS) / vfs) + 1;
+	return (mlx4_roce_mfunc_gid_limit() - MLX4_ROCE_PF_GIDS) / vfs;
 }
 
 int mlx4_get_base_gid_ix(struct mlx4_dev *dev, int slave, int port)
@@ -1136,7 +1194,7 @@ int mlx4_get_base_gid_ix(struct mlx4_dev *dev, int slave, int port)
 		slave_gid -= bitmap_weight(slaves_pport_actv.slaves,
 					   dev->persist->num_vfs + 1);
 	}
-	gids = MLX4_ROCE_MAX_GIDS - MLX4_ROCE_PF_GIDS;
+	gids = mlx4_roce_mfunc_gid_limit() - MLX4_ROCE_PF_GIDS;
 	vfs = bitmap_weight(slaves_pport.slaves, dev->persist->num_vfs + 1) - 1;
 	if (slave_gid <= gids % vfs)
 		return MLX4_ROCE_PF_GIDS + ((gids / vfs) + 1) * (slave_gid - 1);
@@ -1161,9 +1219,12 @@ static int mlx4_reset_roce_port_gids(struct mlx4_dev *dev, int slave,
 
 	mutex_lock(&(priv->port[port].gid_table.mutex));
 	/* Zero-out gids belonging to that slave in the port GID table */
-	for (i = 0, offset = base; i < num_gids; offset++, i++)
+	for (i = 0, offset = base; i < num_gids; offset++, i++) {
 		memcpy(priv->port[port].gid_table.roce_gids[offset].raw,
 		       zgid_entry.raw, MLX4_ROCE_GID_ENTRY_SIZE);
+		priv->port[port].gid_table.gid_type[offset] =
+			MLX4_ROCE_GID_TYPE_INVALID;
+	}
 
 	/* Now, copy roce port gids table to mailbox for passing to FW */
 	gid_entry_mbox = (struct mlx4_roce_gid_entry *)mailbox->buf;
@@ -1342,7 +1403,8 @@ static int mlx4_common_set_port(struct mlx4_dev *dev, int slave, u32 in_mod,
 	if (is_eth) {
 		if (slave != dev->caps.function &&
 		    in_modifier != MLX4_SET_PORT_GENERAL &&
-		    in_modifier != MLX4_SET_PORT_GID_TABLE) {
+		    in_modifier != MLX4_SET_PORT_GID_TABLE &&
+		    in_modifier != MLX4_SET_PORT_ROCE_ADDR) {
 			mlx4_warn(dev, "denying SET_PORT for slave:%d\n",
 					slave);
 			return -EINVAL;
@@ -1381,6 +1443,81 @@ static int mlx4_common_set_port(struct mlx4_dev *dev, int slave, u32 in_mod,
 							      gen_context);
 
 			break;
+		case MLX4_SET_PORT_ROCE_ADDR:
+			num_gids = mlx4_get_slave_num_gids(dev, slave, port);
+			base = mlx4_get_base_gid_ix(dev, slave, port);
+			for (i = 0; i < num_gids; i++) {
+				struct mlx4_roce_addr_mbox_entry *entry =
+					(struct mlx4_roce_addr_mbox_entry *)inbox->buf + i;
+
+				if (!mlx4_roce_addr_entry_valid(entry))
+					return -EINVAL;
+
+				if (!memcmp(entry->gid, zgid_entry.raw,
+					    MLX4_ROCE_GID_ENTRY_SIZE))
+					continue;
+
+				for (j = i + 1; j < num_gids; j++) {
+					struct mlx4_roce_addr_mbox_entry *entry2 =
+						(struct mlx4_roce_addr_mbox_entry *)inbox->buf + j;
+
+					if (!memcmp(entry2->gid, zgid_entry.raw,
+						    MLX4_ROCE_GID_ENTRY_SIZE))
+						continue;
+					if (mlx4_roce_addr_entries_equal(entry, entry2))
+						return -EINVAL;
+				}
+			}
+
+			mutex_lock(&(priv->port[port].gid_table.mutex));
+			for (i = 0; i < MLX4_ROCE_MAX_GIDS; i++) {
+				struct mlx4_roce_gid_entry *gid_entry_tbl;
+
+				if (i >= base && i < base + num_gids)
+					continue;
+
+				gid_entry_tbl = &priv->port[port].gid_table.roce_gids[i];
+				if (!memcmp(gid_entry_tbl->raw, zgid_entry.raw,
+					    MLX4_ROCE_GID_ENTRY_SIZE))
+					continue;
+
+				for (j = 0; j < num_gids; j++) {
+					struct mlx4_roce_addr_mbox_entry *entry =
+						(struct mlx4_roce_addr_mbox_entry *)inbox->buf + j;
+
+					if (!memcmp(entry->gid, zgid_entry.raw,
+						    MLX4_ROCE_GID_ENTRY_SIZE))
+						continue;
+					if (entry->version ==
+					    priv->port[port].gid_table.gid_type[i] &&
+					    !memcmp(entry->gid, gid_entry_tbl->raw,
+						    MLX4_ROCE_GID_ENTRY_SIZE)) {
+						mlx4_warn(dev, "requested gid entry for slave:%d is a duplicate of gid/type at index %d\n",
+							  slave, i);
+						mutex_unlock(&(priv->port[port].gid_table.mutex));
+						return -EINVAL;
+					}
+				}
+			}
+
+			for (i = 0, offset = base; i < num_gids; offset++, i++) {
+				struct mlx4_roce_addr_mbox_entry *entry =
+					(struct mlx4_roce_addr_mbox_entry *)inbox->buf + i;
+
+				memcpy(priv->port[port].gid_table.roce_gids[offset].raw,
+				       entry->gid, MLX4_ROCE_GID_ENTRY_SIZE);
+				priv->port[port].gid_table.gid_type[offset] =
+					memcmp(entry->gid, zgid_entry.raw,
+					       MLX4_ROCE_GID_ENTRY_SIZE) ?
+					entry->version : MLX4_ROCE_GID_TYPE_INVALID;
+			}
+			mlx4_fill_roce_addr_mbox(&priv->port[port].gid_table,
+						inbox->buf);
+			err = mlx4_cmd(dev, inbox->dma, in_mod & 0xffff, op_mod,
+				       MLX4_CMD_SET_PORT, MLX4_CMD_TIME_CLASS_B,
+				       MLX4_CMD_NATIVE);
+			mutex_unlock(&(priv->port[port].gid_table.mutex));
+			return err;
 		case MLX4_SET_PORT_GID_TABLE:
 			/* change to MULTIPLE entries: number of guest's gids
 			 * need a FOR-loop here over number of gids the guest has.
@@ -1435,9 +1572,15 @@ static int mlx4_common_set_port(struct mlx4_dev *dev, int slave, u32 in_mod,
 
 			/* insert slave GIDs with memcpy, starting at slave's base index */
 			gid_entry_mbox = (struct mlx4_roce_gid_entry *)(inbox->buf);
-			for (i = 0, offset = base; i < num_gids; gid_entry_mbox++, offset++, i++)
+			for (i = 0, offset = base; i < num_gids; gid_entry_mbox++, offset++, i++) {
 				memcpy(priv->port[port].gid_table.roce_gids[offset].raw,
 				       gid_entry_mbox->raw, MLX4_ROCE_GID_ENTRY_SIZE);
+				priv->port[port].gid_table.gid_type[offset] =
+					memcmp(gid_entry_mbox->raw, zgid_entry.raw,
+					       MLX4_ROCE_GID_ENTRY_SIZE) ?
+					MLX4_ROCE_GID_TYPE_V1 :
+					MLX4_ROCE_GID_TYPE_INVALID;
+			}
 
 			/* Now, copy roce port gids table to current mailbox for passing to FW */
 			gid_entry_mbox = (struct mlx4_roce_gid_entry *)(inbox->buf);
@@ -1839,7 +1982,7 @@ int mlx4_get_slave_from_roce_gid(struct mlx4_dev *dev, int port, u8 *gid,
